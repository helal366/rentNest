model User{
    id String @id @default(uuid())
    name String
    email String @unique
    role Role 
    password String
    address String 
    contactNo String 
    userStatus UserStatus @default(UNBAN)

    tenantReviews Review[]

    tenantPayments Payment[] @relation("TenantPayments")
    landlordPayments Payment[] @relation("LandlordPayments") 

    tenantRentalRequests RentalRequest[] @relation("TenantRentalRequests")
    approvedRentalProperties Property[] @relation("ApprovedRentalProperties")

    ownProperties Property[] @relation("OwnProperties")
    requestsOwnProperty RentalRequest[] @relation("LandlordRentalRequests")

    isDeleted Boolean @default(false)
    deletedAt DateTime? 
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([id])
    @@map("users")
}